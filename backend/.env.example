# ============================================================
#  Psicoteca - Plantilla de configuración
#  Copia este archivo como ".env" y ajusta los valores (SOLO desarrollo local).
#  En la nube (Render) este archivo NO se sube: define las variables en el panel.
# ============================================================

# --- Credenciales de Google (elige UNA vía) -----------------------------------
# Local: ruta al JSON de la Service Account.
GOOGLE_CREDENTIALS_PATH=D:/CLAUDE PSICO/credentials.json
# Nube (RECOMENDADO): pega el CONTENIDO COMPLETO del credentials.json (en una
# sola línea). Si se define, tiene prioridad sobre GOOGLE_CREDENTIALS_PATH.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...", ...}

# --- Carpeta raíz en Google Drive ---------------------------------------------
ROOT_FOLDER_NAME=PSICOTECA
# Recomendado en la nube: fija el ID EXACTO (evita búsquedas y ambigüedades, y
# evita el sys.exit del sync si la búsqueda por nombre no encontrara la carpeta).
ROOT_FOLDER_ID=

# --- Base de datos SQLite -----------------------------------------------------
# Local. En Render (plan free) el disco es EFÍMERO: puedes omitir esta variable
# (usa el valor por defecto backend/psicoteca.db, que se repuebla en cada
# arranque gracias a SYNC_ON_STARTUP) o, con un disco persistente (plan de
# pago), apuntarla a su punto de montaje, p. ej. /var/data/psicoteca.db
DATABASE_PATH=D:/CLAUDE PSICO/backend/psicoteca.db

DRIVE_PAGE_SIZE=1000

# --- CORS ---------------------------------------------------------------------
# Orígenes autorizados a consumir la API (separados por comas). Incluye el
# dominio de producción del frontend.
CORS_ALLOW_ORIGINS=https://psicoteca.miceliocreate.com,http://localhost:5173,http://127.0.0.1:5173

# --- Fase 4: sincronización automática (APScheduler) --------------------------
SCHEDULER_ENABLED=true        # arranca el planificador en segundo plano
SYNC_INTERVAL_MINUTES=60      # cada cuántos minutos revisar Google Drive
SYNC_ON_STARTUP=true          # lanzar un sync al arrancar (repuebla la BD efímera)
SYNC_JITTER_SECONDS=30        # desfase aleatorio para no disparar en el minuto exacto
# Token para proteger POST /api/sync (disparo manual). Vacío = endpoint deshabilitado.
SYNC_TRIGGER_TOKEN=

# --- Pagos: Stripe + Supabase (Fase 2) ----------------------------------------
# Stripe (modo test para desarrollo). La SECRET key vive solo en el backend.
STRIPE_SECRET_KEY=sk_test_...
# Price recurrente del plan Pro (en MXN), creado en el panel de Stripe.
STRIPE_PRICE_ID=price_...
# Firma del webhook (verifica que los eventos vienen de Stripe):
#  - LOCAL: la imprime `stripe listen --forward-to localhost:8000/api/webhook` (whsec_…).
#  - PRODUCCIÓN: Stripe Dashboard → Developers → Webhooks → endpoint → "Signing secret".
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase.
SUPABASE_URL=https://<ref>.supabase.co
# Clave PÚBLICA (valida el token del usuario). Puede ir también en el frontend.
#  - Sistema nuevo: sb_publishable_…   ·   Legado: JWT "anon" (eyJ…).
SUPABASE_ANON_KEY=sb_publishable_...
# Clave SECRETA de servidor (SOLO backend): el webhook la usa para fijar el plan
# Pro vía la Admin API. NUNCA la expongas en el frontend.
#  - Sistema nuevo: "Secret key" sb_secret_…   ·   Legado: JWT "service_role" (eyJ…).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Base del frontend para las URLs de éxito/cancelación del Checkout.
#  - Local: http://localhost:5173   ·   Producción: https://tu-dominio
FRONTEND_BASE_URL=http://localhost:5173
