# SPA fallback para React Router en Hostinger (Apache).
# Vite copia este archivo a dist/ durante `npm run build`.
# Sin esto, recargar o entrar directo a /login o /register daría un 404,
# porque esas rutas solo existen en el cliente.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # No reescribir archivos o carpetas que existen de verdad (assets, fuentes…).
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Todo lo demás lo sirve index.html (la app se encarga del enrutado).
  RewriteRule ^ index.html [L]
</IfModule>

# --- MIME: forzar JavaScript para .mjs ---------------------------------------
# Hostinger sirve los .mjs como text/plain; el navegador BLOQUEA los module
# workers con MIME no-JS, así que el worker de PDF.js no carga y ningún PDF
# abre ("No se pudo abrir el PDF"). Forzamos un MIME de JavaScript válido.
<IfModule mod_mime.c>
  AddType text/javascript .mjs
</IfModule>

# --- Cache: assets con hash (immutable) cache largo; HTML sin cache ----------
<IfModule mod_headers.c>
  <FilesMatch "\.(js|mjs|css|woff2?|ttf|png|jpe?g|gif|svg|webp|avif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>

# --- Compresión --------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/x-javascript text/javascript application/json image/svg+xml
</IfModule>
